<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0c0f">

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- KARTE                                                               -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- SIDEBAR                                                             -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/sidebar"
        android:layout_width="272dp"
        android:layout_height="0dp"
        android:background="#F00f1216"
        android:elevation="8dp"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="20dp">

            <!-- ── Header ──────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@mipmap/ic_launcher"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Logo" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PAPIER·SAMMLUNG"
                    android:textColor="#00d4ff"
                    android:textSize="13sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="sans-serif-condensed" />

                <ImageButton
                    android:id="@+id/btn_settings"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_preferences"
                    android:background="?android:selectableItemBackgroundBorderless"
                    android:tint="#4a5a6a"
                    android:contentDescription="Einstellungen" />

                <ImageButton
                    android:id="@+id/btn_exit"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_exit"
                    android:background="?android:selectableItemBackgroundBorderless"
                    android:contentDescription="App beenden"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <!-- ── Fahrzeug-Name ──────────────────────────────────── -->
            <TextView
                android:id="@+id/tv_vehicle_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#ffd700"
                android:textSize="17sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="2dp" />

            <!-- ── Status / GPS-Koords ──────────────────────── -->
            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⌛ Warte auf GPS…"
                android:textColor="#4a5a6a"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="2dp" />

            <!-- ── Geschwindigkeit ───────────────────────────────── -->
            <TextView
                android:id="@+id/tv_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#00d4ff"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:visibility="gone"
                android:layout_marginBottom="10dp" />

            <!-- ── Sammel-Button ──────────────────────────────────── -->
            <Button
                android:id="@+id/btn_collect"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="🔴 Nicht am Sammeln"
                android:textColor="#c8d4e0"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1a2530"
                android:layout_marginBottom="10dp" />

            <!-- ── Sammlung ─────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SAMMLUNG"
                android:textColor="#4a5a6a"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_collection_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#4a5a6a"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:visibility="gone"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinner_collection"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="#0a0c0f"
                android:layout_marginBottom="14dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1a2530"
                android:layout_marginBottom="10dp" />

            <!-- ── Routen ───────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ROUTEN"
                android:textColor="#4a5a6a"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:id="@+id/route_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1a2530"
                android:layout_marginBottom="10dp" />

            <!-- ── Fahrzeuge ────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FAHRZEUGE"
                android:textColor="#4a5a6a"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:id="@+id/vehicle_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- SIDEBAR-TOGGLE                                                      -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <ImageButton
        android:id="@+id/btn_toggle_sidebar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_chevron_left"
        android:background="#CC0f1216"
        android:elevation="10dp"
        android:contentDescription="Sidebar ein-/ausblenden"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        android:layout_marginTop="56dp"
        android:layout_marginStart="0dp" />

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- MAP-OVERLAY: Offline-Puffer Banner                                  -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tv_buffered"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#ccff6b35"
        android:textColor="#fff"
        android:textSize="11sp"
        android:padding="6dp"
        android:visibility="gone"
        android:elevation="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- FOLLOW-BUTTON                                                        -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <ImageButton
        android:id="@+id/btn_follow"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:src="@android:drawable/ic_menu_mylocation"
        android:background="#E60f1216"
        android:tint="#00d4ff"
        android:elevation="6dp"
        android:contentDescription="Auf Position zentrieren"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="90dp" />

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- TRACK-TOGGLE BUTTON — Fahrspur anzeigen/verbergen                   -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <ImageButton
        android:id="@+id/btn_toggle_track"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:src="@android:drawable/ic_menu_mapmode"
        android:background="#E60f1216"
        android:tint="#7a9ab0"
        android:elevation="6dp"
        android:contentDescription="Fahrspur anzeigen"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="24dp" />

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- VIEW-ONLY BANNER — Inaktives Gerät                                  -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tv_view_only"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#DD991010"
        android:textColor="#ffcccc"
        android:textSize="12sp"
        android:padding="10dp"
        android:gravity="center"
        android:text="⚠ VIEW ONLY – INAKTIV · Antippen zum Übernehmen"
        android:visibility="gone"
        android:elevation="9dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
