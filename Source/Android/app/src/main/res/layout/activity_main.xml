<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0c0f">

    <!-- Karte (füllt den rechten/unteren Bereich) -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/sidebar"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Follow-Button (erscheint wenn Karte manuell verschoben) -->
    <ImageButton
        android:id="@+id/btn_follow"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@android:drawable/ic_menu_mylocation"
        android:background="#aa0f1216"
        android:tint="#00d4ff"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/map"
        app:layout_constraintEnd_toEndOf="@id/map"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="60dp" />

    <!-- Offline-Puffer-Anzeige -->
    <TextView
        android:id="@+id/tv_buffered"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#ccff6b35"
        android:textColor="#fff"
        android:textSize="11sp"
        android:padding="6dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/map"
        app:layout_constraintStart_toStartOf="@id/map"
        app:layout_constraintEnd_toEndOf="@id/map"
        android:layout_marginTop="8dp" />

    <!-- Sidebar -->
    <ScrollView
        android:id="@+id/sidebar"
        android:layout_width="280dp"
        android:layout_height="0dp"
        android:background="#0f1216"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PAPIER·SAMMLUNG"
                    android:textColor="#00d4ff"
                    android:textSize="14sp"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-condensed" />

                <ImageButton
                    android:id="@+id/btn_settings"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_preferences"
                    android:background="?android:selectableItemBackgroundBorderless"
                    android:tint="#4a5a6a" />
            </LinearLayout>

            <!-- Fahrzeug-Name -->
            <TextView
                android:id="@+id/tv_vehicle_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#ffd700"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="4dp" />

            <!-- Status -->
            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bereit"
                android:textColor="#4a5a6a"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <!-- Geschwindigkeit -->
            <TextView
                android:id="@+id/tv_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#00d4ff"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:visibility="gone"
                android:layout_marginBottom="12dp" />

            <!-- Sammel-Button -->
            <Button
                android:id="@+id/btn_collect"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="🔴 Nicht am Sammeln"
                android:textColor="#c8d4e0"
                android:textSize="13sp"
                android:layout_marginBottom="16dp" />

            <!-- Sammlung auswählen -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SAMMLUNG"
                android:textColor="#4a5a6a"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinner_collection"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="#0a0c0f"
                android:layout_marginBottom="16dp" />

            <!-- Routen-Liste -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ROUTEN"
                android:textColor="#4a5a6a"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:id="@+id/route_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp" />

            <!-- Fahrzeug-Liste -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FAHRZEUGE"
                android:textColor="#4a5a6a"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:id="@+id/vehicle_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
