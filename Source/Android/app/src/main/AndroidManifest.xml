<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- GPS & Hintergrund-GPS -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Netzwerk -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Gerät wach halten beim Sammeln -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Benachrichtigungen (Android 13+, für Foreground-Service-Notification) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Akkuoptimierungs-Ausnahme anfordern -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:name=".PapiersammlungApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.Papiersammlung"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false">

        <!-- Hauptaktivität -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Einstellungen -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="@string/settings" />

        <!-- Login -->
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:label="@string/login" />

        <!--
            GPS Foreground-Service
            android:stopWithTask="false" → Service läuft weiter wenn App via Home minimiert
            oder aus Recents gewischt wird (wichtig für Hintergrund-GPS-Tracking).
        -->
        <service
            android:name=".GpsService"
            android:exported="false"
            android:foregroundServiceType="location"
            android:stopWithTask="false" />

        <!-- Sync-Service -->
        <service
            android:name=".SyncService"
            android:exported="false" />

    </application>

</manifest>
